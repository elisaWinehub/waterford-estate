      "block_order": ["intro_cta"],
      "settings": {
        "show_breadcrumb": true,
        "heading": "",
        "text": "<p>A curated case of our finest releases, delivered to your door every quarter — with member pricing, priority allocation on limited releases, and complimentary tastings at the estate.</p>",
        "text_alignment": "center",
        "max_width": 640,
        "padding_top": 0,
        "padding_bottom": 64
      }
    },
    "wine_club_benefits": {
      "type": "wine-club-benefits",
