        },
        "b5": {
          "type": "benefit_item",
          "settings": {
            "icon": "calendar",
            "heading": "Member tastings",
            "text": "<p>Invitations to seasonal tastings, cellar tours and pairing dinners at the estate, hosted by our winemaking team.</p>"
          }
        },
        "b6": {
          "type": "benefit_item",
          "settings": {
            "icon": "pause",
            "heading": "Pause or cancel anytime",
            "text": "<p>No lock-in contracts. Skip a delivery, change your case size, or cancel your membership whenever you need to.</p>"
          }
        }
