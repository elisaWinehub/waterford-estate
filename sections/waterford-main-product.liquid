{%- comment -%}
  Waterford Estate PDP — literal structure/classes from reference/product-main-page.html
  Purchase options: static mockup .po-wrap UI (wires to selling plans when present).
{%- endcomment -%}

{{ 'waterford-product.css' | asset_url | stylesheet_tag }}
{{ 'waterford-collection.css' | asset_url | stylesheet_tag }}
<script type="module" src="{{ 'waterford-product.js' | asset_url }}"></script>
<script type="module" src="{{ 'waterford-collection.js' | asset_url }}"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign crumb_collection = null
  if collection
    assign crumb_collection = collection
  elsif product.collections.size > 0
    assign crumb_collection = product.collections.first
  endif
  assign has_selling_plans = false
  if product.selling_plan_groups.size > 0
    assign has_selling_plans = true
  endif
-%}

<script type="application/ld+json">
  {{ product | structured_data }}
</script>

<div class="wf-pdp" data-wf-pdp {{ section.shopify_attributes }}>
  <div class="wrap">
    <div class="breadcrumb">
      <a href="{{ routes.all_products_collection_url }}">Shop</a>
      &nbsp;&rsaquo;&nbsp;
      {%- if crumb_collection -%}
        <a href="{{ crumb_collection.url }}">{{ crumb_collection.title }}</a>
      {%- elsif product.type != blank -%}
        <span>{{ product.type }}</span>
      {%- else -%}
        <span>Wine</span>
      {%- endif -%}
      &nbsp;&rsaquo;&nbsp;
      <span>{{ product.title }}</span>
    </div>

    <section class="pdp-top">
      <div>
        {%- for block in section.blocks -%}
          {%- if block.type == 'gallery' -%}
            {% render 'wf-pdp-gallery', product: product, block: block %}
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="pdp-info">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'title' -%}
              <h1 class="serif pdp-title" {{ block.shopify_attributes }}>{{ product.title }}</h1>

            {%- when 'tagline' -%}
              {%- liquid
                assign tagline = product.metafields.custom.tagline.value | default: product.metafields.custom.tagline
                if tagline == blank
                  assign tagline = block.settings.fallback_text
                endif
                if tagline == blank
                  assign tagline = product.description | strip_html | truncate: 220
                endif
              -%}
              {%- if tagline != blank -%}
                <p class="pdp-tagline" {{ block.shopify_attributes }}>{{ tagline }}</p>
              {%- endif -%}

            {%- when 'awards' -%}
              {%- liquid
                assign awards = product.metafields.custom.awards.value
              -%}
              {%- if awards != blank or block.settings.award_1 != blank -%}
                <div class="medals-row" {{ block.shopify_attributes }}>
                  {%- if awards != blank -%}
                    {%- for award in awards -%}
                      {%- liquid
                        assign badge = award.badge_image.value | default: award.badge_image
                        assign badge_alt = award.badge_alt.value | default: award.badge_alt
                        if badge_alt == blank
                          assign pub = award.publication.value | default: award.publication
                          assign yr = award.award_year.value | default: award.award_year
                          assign badge_alt = pub | append: ' ' | append: yr | strip
                        endif
                        if badge_alt == blank
                          assign badge_alt = 'Award'
                        endif
                      -%}
                      {%- if badge != blank -%}
                        <img
                          src="{{ badge | image_url: width: 160 }}"
                          alt="{{ badge_alt | escape }}"
                          loading="lazy"
                          width="80"
                          height="80"
                        >
                      {%- else -%}
                        <span class="medal-text" title="{{ badge_alt | escape }}">
                          {%- assign rating = award.rating.value | default: award.rating -%}
                          {%- if rating != blank -%}{{ rating }}{%- else -%}{{ badge_alt }}{%- endif -%}
                        </span>
                      {%- endif -%}
                    {%- endfor -%}
                  {%- else -%}
                    {%- if block.settings.award_1 != blank -%}
                      <img src="{{ block.settings.award_1 | image_url: width: 160 }}" alt="{{ block.settings.award_1_alt | default: 'Award' | escape }}" loading="lazy" height="58" width="auto">
                    {%- endif -%}
                    {%- if block.settings.award_2 != blank -%}
                      <img src="{{ block.settings.award_2 | image_url: width: 160 }}" alt="{{ block.settings.award_2_alt | default: 'Award' | escape }}" loading="lazy" height="58" width="auto">
                    {%- endif -%}
                    {%- if block.settings.award_3 != blank -%}
                      <img src="{{ block.settings.award_3 | image_url: width: 160 }}" alt="{{ block.settings.award_3_alt | default: 'Award' | escape }}" loading="lazy" height="58" width="auto">
                    {%- endif -%}
                  {%- endif -%}
                </div>
              {%- endif -%}

            {%- when 'price' -%}
              {%- liquid
                assign unit_label = block.settings.unit_label | strip
                if current_variant.weight > 0
                  assign unit_label = current_variant.weight | append: ' ' | append: current_variant.weight_unit | strip
                endif
                assign unit_label = unit_label | remove_first: '/' | strip
              -%}
              <div class="price-box" {{ block.shopify_attributes }} data-wf-price data-base-cents="{{ current_variant.price }}">
                <div class="price">
                  <s class="price-compare" data-wf-compare-price hidden></s>
                  <span data-wf-price-value>{{ current_variant.price | money }}</span>
                  <span class="price-badge" data-wf-discount-badge hidden></span>
                  {%- if unit_label != blank -%}
                    <small>/ {{ unit_label }}</small>
                  {%- endif -%}
                </div>
              </div>

            {%- when '@app' -%}
              {%- comment -%} Optional app slot (reviews, etc.) {%- endcomment -%}
              <div {{ block.shopify_attributes }}>{% render block %}</div>

            {%- when 'purchase_option' -%}
              {%- liquid
                assign show_po = block.settings.enable_purchase_options
                if show_po == nil
                  assign show_po = true
                endif
                assign d1 = block.settings.discount_1 | default: 10
                assign d2 = block.settings.discount_2 | default: 15
                assign d3 = block.settings.discount_3 | default: 20
                assign price_cents = current_variant.price
                assign factor1 = 100 | minus: d1
                assign factor2 = 100 | minus: d2
                assign factor3 = 100 | minus: d3
                assign sale1 = price_cents | times: factor1 | divided_by: 100
                assign sale2 = price_cents | times: factor2 | divided_by: 100
                assign sale3 = price_cents | times: factor3 | divided_by: 100
              -%}
              {%- if show_po -%}
                <div
                  class="po-wrap"
                  data-wf-po
                  data-base-cents="{{ price_cents }}"
                  data-money-format="{{ shop.money_format | escape }}"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.heading != blank -%}
                    <p class="po-heading">{{ block.settings.heading }}</p>
                  {%- endif -%}

                  <div class="po-card is-selected" data-wf-po-card data-po-type="onetime" data-discount="0">
                    <label class="po-card__row">
                      <input
                        type="radio"
                        name="purchase_option"
                        value="one_time"
                        data-po-type="onetime"
                        data-selling-plan=""
                        data-discount="0"
                        checked
                      >
                      <span class="po-card__label">{{ block.settings.onetime_label | default: 'One-time purchase' }}</span>
                      <span class="po-card__price" data-po-card-price>{{ price_cents | money }}</span>
                    </label>
                  </div>

                  {%- if has_selling_plans -%}
                    {%- for group in product.selling_plan_groups -%}
                      <div class="po-card" data-wf-po-card data-po-type="subscribe">
                        <label class="po-card__row">
                          <input
                            type="radio"
                            name="purchase_option"
                            value="subscribe"
                            data-po-type="subscribe"
                            data-selling-plan=""
                          >
                          <span class="po-card__label">{{ block.settings.subscribe_label | default: group.name }}</span>
                          <span class="po-card__price" data-po-card-price></span>
                        </label>
                        <div class="po-frequency">
                          <label class="po-freq-label" for="po-freq-{{ block.id }}-{{ group.id }}">Delivery frequency</label>
                          <select
                            class="po-freq-select"
                            id="po-freq-{{ block.id }}-{{ group.id }}"
                            data-po-freq-select
                            {% unless forloop.first %}disabled{% endunless %}
                          >
                            {%- for plan in group.selling_plans -%}
                              {%- liquid
                                assign plan_discount = 0
                                assign plan_sale = price_cents
                                if plan.price_adjustments.size > 0
                                  assign adj = plan.price_adjustments.first
                                  if adj.value_type == 'percentage'
                                    assign plan_discount = adj.value
                                    assign plan_sale = price_cents | times: 100 | minus: adj.value | divided_by: 100
                                  elsif adj.value_type == 'fixed_amount'
                                    assign plan_sale = price_cents | minus: adj.value
                                    if price_cents > 0
                                      assign plan_discount = adj.value | times: 100.0 | divided_by: price_cents | round
                                    endif
                                  endif
                                endif
                              -%}
                              <option
                                value="{{ plan.id }}"
                                data-selling-plan="{{ plan.id }}"
                                data-discount="{{ plan_discount }}"
                                data-sale-cents="{{ plan_sale }}"
                              >
                                {{ plan.name }}{% if plan_discount > 0 %} — {{ plan_discount }}% off{% endif %}
                              </option>
                            {%- endfor -%}
                          </select>
                        </div>
                      </div>
                    {%- endfor -%}
                  {%- else -%}
                    {%- comment -%} Demo static subscribe UI with dropdown + live discount pricing {%- endcomment -%}
                    <div class="po-card" data-wf-po-card data-po-type="subscribe" data-po-static="true">
                      <label class="po-card__row">
                        <input
                          type="radio"
                          name="purchase_option"
                          value="subscribe"
                          data-po-type="subscribe"
                          data-selling-plan=""
                          data-po-static="true"
                          data-discount="{{ d1 }}"
                        >
                        <span class="po-card__label">
                          {{ block.settings.subscribe_label | default: 'Subscribe & Save' }}
                          <span class="po-save-badge" data-po-save-badge>{{ d1 }}% off</span>
                        </span>
                        <span class="po-card__price" data-po-card-price>
                          <s class="po-compare">{{ price_cents | money }}</s>
                          <span class="po-sale">{{ sale1 | money }}</span>
                        </span>
                      </label>
                      <div class="po-frequency">
                        <label class="po-freq-label" for="po-freq-{{ block.id }}">Delivery frequency</label>
                        <select class="po-freq-select" id="po-freq-{{ block.id }}" data-po-freq-select disabled>
                          <option
                            value="freq-1"
                            data-discount="{{ d1 }}"
                            data-sale-cents="{{ sale1 }}"
                            selected
                          >
                            {{ block.settings.freq_1 | default: 'Every month' }} — {{ d1 }}% off
                          </option>
                          <option
                            value="freq-2"
                            data-discount="{{ d2 }}"
                            data-sale-cents="{{ sale2 }}"
                          >
                            {{ block.settings.freq_2 | default: 'Every 2 months' }} — {{ d2 }}% off
                          </option>
                          <option
                            value="freq-3"
                            data-discount="{{ d3 }}"
                            data-sale-cents="{{ sale3 }}"
                          >
                            {{ block.settings.freq_3 | default: 'Every 3 months' }} — {{ d3 }}% off
                          </option>
                        </select>
                      </div>
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}

            {%- when 'buy_buttons' -%}
              {% form 'product', product, class: 'buy-actions', data-wf-buy-form: '' %}
                <input type="hidden" name="id" value="{{ current_variant.id }}">
                <input type="hidden" name="quantity" value="1" data-wf-qty-input>
                <input type="hidden" name="selling_plan" value="" data-wf-selling-plan>

                {%- unless product.has_only_default_variant -%}
                  <select class="variant-select" data-wf-variant-select aria-label="{{ 'products.product.product_variants' | t }}">
                    {%- for variant in product.variants -%}
                      <option
                        value="{{ variant.id }}"
                        data-available="{{ variant.available }}"
                        {% if variant == current_variant %}selected{% endif %}
                      >
                        {{ variant.title }} — {{ variant.price | money }}
                      </option>
                    {%- endfor -%}
                  </select>
                {%- endunless -%}

                {%- if current_variant.available -%}
                  <div class="qty" data-wf-qty>
                    <button type="button" data-qty-dec aria-label="{{ 'accessibility.decrease_quantity' | t }}">–</button>
                    <span id="qtyVal" data-qty-value aria-live="polite">1</span>
                    <button type="button" data-qty-inc aria-label="{{ 'accessibility.increase_quantity' | t }}">+</button>
                  </div>
                  <button
                    type="submit"
                    class="button buy-btn"
                    data-wf-buy-submit
                    data-label-add="{{ 'products.product.add_to_cart' | t | escape }}"
                    data-label-adding="{{ 'products.product.adding_to_cart' | t | escape }}"
                    data-label-added="{{ 'products.product.added_to_cart' | t | escape }}"
                    data-label-error="{{ 'products.product.add_to_cart_error' | t | escape }}"
                    data-label-sold="{{ 'products.product.sold_out' | t | escape }}"
                  >
                    {{ 'products.product.add_to_cart' | t }}
                  </button>
                {%- else -%}
                  <button type="button" class="button buy-btn" disabled>{{ 'products.product.sold_out' | t }}</button>
                {%- endif -%}
              {% endform %}

            {%- when 'shipping_note' -%}
              {%- liquid
                assign note = product.metafields.custom.shipping_note.value | default: product.metafields.custom.shipping_note
                if note == blank
                  assign note = block.settings.text
                endif
              -%}
              {%- if note != blank -%}
                <div class="ship-note" {{ block.shopify_attributes }}>{{ note }}</div>
              {%- endif -%}

            {%- when 'quick_facts' -%}
              {%- liquid
                assign f1_value = product.metafields.custom.vintage.value | default: product.metafields.custom.fact_1.value | default: block.settings.fact_1_value
                assign f2_value = product.metafields.custom.alcohol.value | default: product.metafields.custom.fact_2.value | default: block.settings.fact_2_value
                assign f3_value = product.metafields.custom.blend_summary.value | default: product.metafields.custom.blend.value | default: product.metafields.custom.fact_3.value | default: block.settings.fact_3_value
                assign f4_value = product.metafields.custom.new_oak.value | default: product.metafields.custom.oak.value | default: product.metafields.custom.fact_4.value | default: block.settings.fact_4_value
                assign has_facts = false
                if f1_value != blank or f2_value != blank or f3_value != blank or f4_value != blank
                  assign has_facts = true
                endif
              -%}
              {%- if has_facts -%}
                <div class="quickfacts" {{ block.shopify_attributes }}>
                  {%- if f1_value != blank -%}<div class="qf"><b>{{ f1_value }}</b><span>{{ block.settings.fact_1_label | default: 'Vintage' }}</span></div>{%- endif -%}
                  {%- if f2_value != blank -%}<div class="qf"><b>{{ f2_value }}</b><span>{{ block.settings.fact_2_label | default: 'Alcohol' }}</span></div>{%- endif -%}
                  {%- if f3_value != blank -%}<div class="qf"><b>{{ f3_value }}</b><span>{{ block.settings.fact_3_label | default: 'Blend' }}</span></div>{%- endif -%}
                  {%- if f4_value != blank -%}<div class="qf"><b>{{ f4_value }}</b><span>{{ block.settings.fact_4_label | default: 'New oak' }}</span></div>{%- endif -%}
                </div>
              {%- endif -%}

            {%- when 'details_heading' -%}
              <div {{ block.shopify_attributes }}>
                <div class="divider"></div>
                <h2 class="serif section-title">{{ block.settings.heading | default: 'Details' }}</h2>
              </div>
              <div class="accordion">
                {%- for acc_block in section.blocks -%}
                  {%- case acc_block.type -%}
                    {%- when 'accordion_tasting' -%}
                      {%- liquid
                        assign appearance = product.metafields.custom.appearance.value | default: acc_block.settings.appearance
                        assign nose = product.metafields.custom.nose.value | default: acc_block.settings.nose
                        assign palate = product.metafields.custom.palate.value | default: acc_block.settings.palate
                      -%}
                      {%- capture acc_body -%}
                        <div class="tasting-grid">
                          <div><h4>{{ acc_block.settings.label_appearance }}</h4><p>{% if appearance != blank %}{{ appearance }}{% endif %}</p></div>
                          <div><h4>{{ acc_block.settings.label_nose }}</h4><p>{% if nose != blank %}{{ nose }}{% endif %}</p></div>
                          <div><h4>{{ acc_block.settings.label_palate }}</h4><p>{% if palate != blank %}{{ palate }}{% endif %}</p></div>
                        </div>
                      {%- endcapture -%}
                      {% render 'wf-pdp-accordion-item', block: acc_block, heading: acc_block.settings.heading, open: acc_block.settings.open_by_default, body: acc_body %}

                    {%- when 'accordion_wine_details' -%}
                      {%- liquid
                        assign region = product.metafields.custom.region.value | default: acc_block.settings.region
                        assign release = product.metafields.custom.release_date.value | default: acc_block.settings.release_date
                        assign cases = product.metafields.custom.cases_produced.value | default: acc_block.settings.cases_produced
                        assign closure = product.metafields.custom.closure.value | default: acc_block.settings.closure
                        assign blend_html = product.metafields.custom.blend_composition.value | default: acc_block.settings.blend_html
                        assign analysis_html = product.metafields.custom.technical_analysis.value | default: acc_block.settings.analysis_html
                      -%}
                      {%- capture acc_body -%}
                        <div class="acc-sub">{{ acc_block.settings.sub_glance }}</div>
                        <div class="stat-grid">
                          <div class="stat"><b>{% if region != blank %}{{ region }}{% endif %}</b><span>{{ acc_block.settings.label_region }}</span></div>
                          <div class="stat"><b>{% if release != blank %}{{ release }}{% endif %}</b><span>{{ acc_block.settings.label_release }}</span></div>
                          <div class="stat"><b>{% if cases != blank %}{{ cases }}{% endif %}</b><span>{{ acc_block.settings.label_cases }}</span></div>
                          <div class="stat"><b>{% if closure != blank %}{{ closure }}{% endif %}</b><span>{{ acc_block.settings.label_closure }}</span></div>
                        </div>
                        <div class="acc-sub">{{ acc_block.settings.sub_blend }}</div>
                        {% if blend_html != blank %}{{ blend_html }}{% endif %}
                        <div class="acc-sub">{{ acc_block.settings.sub_analysis }}</div>
                        {% if analysis_html != blank %}{{ analysis_html }}{% endif %}
                      {%- endcapture -%}
                      {% render 'wf-pdp-accordion-item', block: acc_block, heading: acc_block.settings.heading, open: acc_block.settings.open_by_default, body: acc_body %}

                    {%- when 'accordion_vineyard' -%}
                      {%- liquid
                        assign vineyard_html = product.metafields.custom.vineyard_winemaking.value | default: acc_block.settings.body_html
                      -%}
                      {%- capture acc_body -%}
                        {% if vineyard_html != blank %}
                          {{ vineyard_html }}
                        {% else %}
                          <div class="acc-sub">The vineyard</div>
                          <div class="acc-sub">In the cellar</div>
                          <div class="acc-sub">Maturation</div>
                        {% endif %}
                      {%- endcapture -%}
                      {% render 'wf-pdp-accordion-item', block: acc_block, heading: acc_block.settings.heading, open: acc_block.settings.open_by_default, body: acc_body %}

                    {%- when 'accordion_ageing' -%}
                      {%- liquid
                        assign ageing_html = product.metafields.custom.ageing_shipping.value | default: acc_block.settings.body_html
                      -%}
                      {%- capture acc_body -%}
                        {% if ageing_html != blank %}
                          {{ ageing_html }}
                        {% else %}
                          <div class="acc-sub">Ageing potential</div>
                          <div class="acc-sub">Shipping &amp; delivery</div>
                        {% endif %}
                      {%- endcapture -%}
                      {% render 'wf-pdp-accordion-item', block: acc_block, heading: acc_block.settings.heading, open: acc_block.settings.open_by_default, body: acc_body %}
                  {%- endcase -%}
                {%- endfor -%}
              </div>

            {%- when 'accordion_tasting', 'accordion_wine_details', 'accordion_vineyard', 'accordion_ageing' -%}
              {%- comment -%} Rendered inside details_heading accordion wrapper {%- endcomment -%}

            {%- when 'utility_line' -%}
              <div class="utility-line" {{ block.shopify_attributes }}>
                {{ block.settings.prefix }}
                {%- if block.settings.ask_url != blank -%}
                  <a href="{{ block.settings.ask_url }}">{{ block.settings.ask_label }}</a>
                {%- endif -%}
                <span class="sep">·</span>
                <a href="{{ block.settings.review_url | default: product.url | append: '#reviews' }}">{{ block.settings.review_label }}</a>
              </div>

            {%- when 'media_cards' -%}
              {%- comment -%} rendered below pdp-top {%- endcomment -%}

            {%- when 'gallery' -%}
              {%- comment -%} rendered in left column {%- endcomment -%}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </section>

    {%- for block in section.blocks -%}
      {%- if block.type == 'media_cards' -%}
        {%- liquid
          assign video_url = product.metafields.custom.video_url.value | default: block.settings.video_url
          assign video_title = product.metafields.custom.video_title.value | default: block.settings.video_title
          assign video_thumb = product.metafields.custom.video_thumbnail.value | default: block.settings.video_image
          assign journal = product.metafields.custom.journal_article.value
          assign journal_url = block.settings.journal_url
          assign journal_title = block.settings.journal_title
          if journal != blank
            assign journal_url = journal.url
            assign journal_title = journal.title
          endif
          assign dist_flags_raw = product.metafields.custom.distributors.value | default: block.settings.dist_flags
          assign show_video = false
          assign show_journal = false
          assign show_dist = false
          if video_url != blank
            assign show_video = true
          endif
          if journal_url != blank
            assign show_journal = true
          endif
          if dist_flags_raw != blank or block.settings.dist_url != blank
            assign show_dist = true
          endif
        -%}
        {%- if show_video or show_journal or show_dist -%}
          <div {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <div class="media-head">
                <h2 class="serif">{{ block.settings.heading }}</h2>
                {%- if block.settings.subheading != blank -%}
                  <p>{{ block.settings.subheading }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
            <div class="media-grid">
              {%- if show_video -%}
                <a class="media-card" href="{{ video_url | default: '#' }}" {% if video_url != blank %}target="_blank" rel="noopener"{% endif %}>
                  <div class="media-thumb">
                    {%- if video_thumb != blank -%}
                      {{ video_thumb | image_url: width: 800 | image_tag: loading: 'lazy', alt: video_title }}
                    {%- endif -%}
                    <div class="play-btn" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                    </div>
                  </div>
                  <div class="media-body">
                    <div class="media-eyebrow">{{ block.settings.video_eyebrow }}</div>
                    <div class="media-title">{{ video_title }}</div>
                    {%- if block.settings.video_desc != blank -%}<p class="media-desc">{{ block.settings.video_desc }}</p>{%- endif -%}
                    <span class="media-cta">{{ block.settings.video_cta }}</span>
                  </div>
                </a>
              {%- endif -%}

              {%- if show_journal -%}
                <a class="media-card" href="{{ journal_url | default: '#' }}">
                  <div class="media-thumb">
                    {%- if journal.image != blank -%}
                      {{ journal.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: journal_title }}
                    {%- elsif block.settings.journal_image != blank -%}
                      {{ block.settings.journal_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: journal_title }}
                    {%- endif -%}
                  </div>
                  <div class="media-body">
                    <div class="media-eyebrow">{{ block.settings.journal_eyebrow }}</div>
                    <div class="media-title">{{ journal_title }}</div>
                    {%- if block.settings.journal_desc != blank -%}<p class="media-desc">{{ block.settings.journal_desc }}</p>{%- endif -%}
                    <span class="media-cta">{{ block.settings.journal_cta }}</span>
                  </div>
                </a>
              {%- endif -%}

              {%- if show_dist -%}
                <a class="media-card" href="{{ block.settings.dist_url | default: '#' }}">
                  <div class="media-thumb">
                    <div class="flag-row">
                      {%- assign flags = dist_flags_raw | split: ',' -%}
                      {%- for flag in flags -%}
                        {%- if flag != blank -%}
                          <span class="flag-pill">{{ flag | strip }}</span>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  </div>
                  <div class="media-body">
                    <div class="media-eyebrow">{{ block.settings.dist_eyebrow }}</div>
                    <div class="media-title">{{ block.settings.dist_title }}</div>
                    {%- if block.settings.dist_desc != blank -%}<p class="media-desc">{{ block.settings.dist_desc }}</p>{%- endif -%}
                    <span class="media-cta">{{ block.settings.dist_cta }}</span>
                  </div>
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

