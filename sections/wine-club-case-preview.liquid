{%- comment -%}
  Wine Club case preview — reuses waterford-product-card.
  Collection setting wins over manual product blocks when set.
{%- endcomment -%}

{{ 'wine-club.css' | asset_url | stylesheet_tag }}
{{ 'waterford-collection.css' | asset_url | stylesheet_tag }}
<script type="module" src="{{ 'waterford-collection.js' | asset_url }}"></script>

{%- liquid
  assign cols = section.settings.columns_desktop | default: '3'
  assign limit = section.settings.products_to_show | default: 3
  assign use_collection = false
  if section.settings.collection != blank
    assign use_collection = true
  endif
-%}

<section
  class="wine-club wine-club-case"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; --wc-cols: {{ cols }};"
  {{ section.shopify_attributes }}
>
  <div class="wine-club__wrap">
    <div class="wine-club-case__head">
      {%- if section.settings.eyebrow_text != blank -%}
        <div class="wine-club__eyebrow">{{ section.settings.eyebrow_text }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="serif wine-club__heading wine-club__heading--{{ section.settings.heading_size | default: 'large' }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="wine-club-case__desc">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="wine-club-case__grid">
      {%- if use_collection -%}
        {%- for product in section.settings.collection.products limit: limit -%}
          {% render 'waterford-product-card', product: product, index: forloop.index0 %}
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' and block.settings.product != blank -%}
            <div {{ block.shopify_attributes }}>
              {% render 'waterford-product-card', product: block.settings.product, index: forloop.index0 %}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wine Club case preview",
  "tag": "section",
  "class": "section-wine-club-case",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    {
      "type": "paragraph",
      "content": "If a collection is selected, products are pulled from that collection and manual product blocks are ignored. Clear the collection to use manual product blocks instead."
    },
    { "type": "text", "id": "eyebrow_text", "label": "Eyebrow", "default": "A Taste of What's Inside" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "This quarter's selection" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "xlarge", "label": "X-Large" }
      ],
      "default": "large"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>A preview of the wines currently featured in the Wine Club case — the exact selection varies each quarter.</p>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection (auto-pull)",
      "info": "Optional. When set, products come from this collection."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products to show",
      "default": 3,
      "info": "Only used when a collection is selected"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 84
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Used only when Collection is empty"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Wine Club case preview"
    }
  ]
}
{% endschema %}
