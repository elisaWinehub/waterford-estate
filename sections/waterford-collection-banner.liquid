{%- comment -%}
  Waterford Estate collection hero banner.
  Uses the collection featured image from Admin (Products → Collections),
  with an optional section fallback image.
{%- endcomment -%}

{{ 'waterford-collection.css' | asset_url | stylesheet_tag }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

{%- liquid
  assign hero_image = collection.image
  if hero_image == blank
    assign hero_image = collection.featured_image
  endif
  if hero_image == blank
    assign hero_image = section.settings.fallback_image
  endif

  assign eyebrow = section.settings.eyebrow_label | default: 'Wine collection'
  assign hero_alt = collection.title | escape
  assign has_hero_image = false
  if hero_image != blank
    assign has_hero_image = true
  endif
-%}

<section
  class="wf-collection wf-hero{% if has_hero_image %} wf-hero--has-image{% endif %}"
  {% if has_hero_image %}
    style="--wf-hero-image: url('{{ hero_image | image_url: width: 2400 }}');"
  {% endif %}
  {{ section.shopify_attributes }}
>
  {%- if has_hero_image -%}
    <div class="wf-hero__media">
      {{
        hero_image
        | image_url: width: 2400
        | image_tag:
          widths: '800, 1200, 1600, 2000, 2400',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high',
          class: 'wf-hero__img',
          alt: hero_alt
      }}
    </div>
  {%- endif -%}
  <div class="wf-hero__overlay" aria-hidden="true"></div>
  <div class="wf-hero__content">
    {%- if eyebrow != blank -%}
      <div class="wf-hero__eyebrow">{{ eyebrow }}</div>
    {%- endif -%}
    <h1 class="wf-hero__title serif">{{ collection.title }}</h1>
  </div>
</section>

{% schema %}
{
  "name": "WF Collection banner",
  "tag": "section",
  "class": "section-waterford-collection-banner",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow_label",
      "label": "Eyebrow label",
      "default": "Wine collection",
      "info": "Static label shown above the collection title"
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback hero image",
      "info": "Used when the collection has no featured image in Admin"
    }
  ],
  "presets": [
    {
      "name": "WF Collection banner"
    }
  ]
}
{% endschema %}
