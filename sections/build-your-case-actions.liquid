{%- comment -%}
  Build Your Case actions — Go back / Continue row below the step flow.
  Continue destination is a placeholder until WineHub Quantity step is confirmed.
{%- endcomment -%}

{{ 'build-your-case.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign back_href = section.settings.back_link
  if back_href == blank
    assign back_href = '/pages/wine-club#cases'
  endif
-%}

<section
  class="byc byc-actions"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  {{ section.shopify_attributes }}
>
  <div class="byc__wrap">
    <div class="byc-actions__row">
      {%- if section.settings.back_text != blank -%}
        <a class="byc-actions__back" href="{{ back_href }}">
          ← {{ section.settings.back_text }}
        </a>
      {%- endif -%}
      {%- if section.settings.continue_text != blank -%}
        {%- if section.settings.continue_link != blank -%}
          <a class="byc-actions__continue" href="{{ section.settings.continue_link }}">
            {{ section.settings.continue_text }}
          </a>
        {%- else -%}
          <button type="button" class="byc-actions__continue" disabled aria-disabled="true">
            {{ section.settings.continue_text }}
          </button>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BYC actions",
  "tag": "section",
  "class": "section-build-your-case-actions",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    {
      "type": "text",
      "id": "back_text",
      "label": "Back button text",
      "default": "Go back"
    },
    {
      "type": "url",
      "id": "back_link",
      "label": "Back link",
      "info": "Defaults to /pages/wine-club#cases when blank"
    },
    {
      "type": "text",
      "id": "continue_text",
      "label": "Continue button text",
      "default": "Continue to Quantity"
    },
    {
      "type": "url",
      "id": "continue_link",
      "label": "Continue link",
      "info": "Leave blank until the Quantity step / WineHub destination is confirmed. Button stays visible but disabled when unset."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "presets": [
    { "name": "BYC actions" }
  ]
}
{% endschema %}
