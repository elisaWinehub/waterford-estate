{%- comment -%}
  Membership tiers — Bronze / Silver / Gold comparison grid (repeatable blocks)
{%- endcomment -%}

{{ 'membership.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign cols = section.settings.columns_desktop | default: '3'
-%}

<section
  class="membership membership-tiers"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; --ms-tier-cols: {{ cols }};"
  {{ section.shopify_attributes }}
>
  <div class="membership__wrap">
    {%- if section.settings.eyebrow_text != blank or section.settings.heading != blank -%}
      <div class="membership-tiers__head">
        {%- if section.settings.eyebrow_text != blank -%}
          <div class="membership__eyebrow">{{ section.settings.eyebrow_text }}</div>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="serif membership__heading membership__heading--{{ section.settings.heading_size | default: 'large' }}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="membership-tiers__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'tier_card' -%}
            <article
              class="membership-tier-card{% if block.settings.featured %} membership-tier-card--featured{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.badge_text != blank -%}
                <div class="membership-tier-card__badge">{{ block.settings.badge_text }}</div>
              {%- endif -%}
              {%- if block.settings.name != blank -%}
                <div class="membership-tier-card__name">{{ block.settings.name }}</div>
              {%- endif -%}
              {%- if block.settings.price != blank or block.settings.price_suffix != blank -%}
                <div class="membership-tier-card__price">
                  {%- if block.settings.price != blank -%}{{ block.settings.price }}{%- endif -%}
                  {%- if block.settings.price_suffix != blank -%}
                    <small>{{ block.settings.price_suffix }}</small>
                  {%- endif -%}
                </div>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <div class="membership-tier-card__desc">{{ block.settings.description }}</div>
              {%- endif -%}
              {%- if block.settings.benefits != blank -%}
                <div class="membership-tier-card__benefits">
                  {{ block.settings.benefits }}
                </div>
              {%- endif -%}
              {%- if block.settings.button_text != blank -%}
                <a
                  class="membership-tier-card__btn"
                  href="{{ block.settings.button_link | default: '#' }}"
                >
                  {{ block.settings.button_text }}
                </a>
              {%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.note_text != blank -%}
      <div class="membership-tiers__note">{{ section.settings.note_text }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Membership tiers",
  "tag": "section",
  "class": "section-membership-tiers",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    { "type": "text", "id": "eyebrow_text", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "xlarge", "label": "X-Large" }
      ],
      "default": "large"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "richtext",
      "id": "note_text",
      "label": "Closing note",
      "default": "<p>Not sure which tier is right for you? <a href=\"/pages/wine-club\" title=\"Wine Club\">Compare our Wine Club cases</a> or <a href=\"/pages/contact\" title=\"Contact\">get in touch</a> and our team will help you choose.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "tier_card",
      "name": "Tier card",
      "settings": [
        { "type": "text", "id": "name", "label": "Tier name", "default": "Bronze" },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured / highlighted style",
          "default": false
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge text",
          "info": "Optional — e.g. Most Popular. Shown only when not blank."
        },
        { "type": "text", "id": "price", "label": "Price", "default": "R 650.00" },
        {
          "type": "text",
          "id": "price_suffix",
          "label": "Price suffix",
          "default": "/ quarter"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>An easy introduction to membership, with two bottles from our Estate Range every quarter.</p>"
        },
        {
          "type": "richtext",
          "id": "benefits",
          "label": "Benefits list",
          "default": "<ul><li>Two bottles per quarter</li><li>Member pricing on all purchases</li><li>Complimentary shipping</li><li>Pause or cancel anytime</li></ul>",
          "info": "Use the rich text editor’s bulleted list for benefits."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Join the Club"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link",
          "info": "Destination for Join the Club — e.g. the upcoming Build Your Case page"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Membership tiers",
      "blocks": [
        {
          "type": "tier_card",
          "settings": {
            "name": "Bronze",
            "featured": false,
            "price": "R 650.00",
            "price_suffix": "/ quarter",
            "description": "<p>An easy introduction to membership, with two bottles from our Estate Range every quarter.</p>",
            "benefits": "<ul><li>Two bottles per quarter</li><li>Member pricing on all purchases</li><li>Complimentary shipping</li><li>Pause or cancel anytime</li></ul>",
            "button_text": "Join the Club"
          }
        },
        {
          "type": "tier_card",
          "settings": {
            "name": "Silver",
            "featured": true,
            "badge_text": "Most Popular",
            "price": "R 950.00",
            "price_suffix": "/ quarter",
            "description": "<p>Our most popular tier — four bottles per quarter with priority allocation on limited releases.</p>",
            "benefits": "<ul><li>Four bottles per quarter</li><li>Priority allocation on limited releases</li><li>Two complimentary tastings a year</li><li>Complimentary shipping</li><li>Pause or cancel anytime</li></ul>",
            "button_text": "Join the Club"
          }
        },
        {
          "type": "tier_card",
          "settings": {
            "name": "Gold",
            "featured": false,
            "price": "R 1,450.00",
            "price_suffix": "/ quarter",
            "description": "<p>Full access to Waterford Estate — six bottles per quarter, including library and flagship releases.</p>",
            "benefits": "<ul><li>Six bottles per quarter, including library releases</li><li>First access to The Jem and single-vineyard wines</li><li>Quarterly member tastings and cellar tours</li><li>Access to The Jem Room for private bookings</li><li>Complimentary shipping</li></ul>",
            "button_text": "Join the Club"
          }
        }
      ]
    }
  ]
}
{% endschema %}
