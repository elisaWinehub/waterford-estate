{%- comment -%}
  Wine Club FAQ — native details/summary accordion (same pattern as PDP)
{%- endcomment -%}

{{ 'wine-club.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign max_w = section.settings.max_width | default: 760
-%}

<section
  class="wine-club wine-club-faq color-{{ section.settings.color_scheme }}"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  {{ section.shopify_attributes }}
>
  <div class="wine-club__wrap">
    <div class="wine-club-faq__head">
      {%- if section.settings.eyebrow_text != blank -%}
        <div class="wine-club__eyebrow">{{ section.settings.eyebrow_text }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="serif wine-club__heading wine-club__heading--{{ section.settings.heading_size | default: 'large' }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="wine-club-faq__accordion" style="max-width: {{ max_w }}px;">
        {%- for block in section.blocks -%}
          {%- if block.type == 'question' and block.settings.question != blank -%}
            <details
              class="wine-club-faq__item"
              {% if block.settings.default_open %}open{% endif %}
              {{ block.shopify_attributes }}
            >
              <summary>
                <span>{{ block.settings.question }}</span>
                <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M2.6 6.3 3.4 5.1l4.6 4.2 4.6-4.2.8 1.2-5.4 5.3z"/>
                </svg>
              </summary>
              {%- if block.settings.answer != blank -%}
                <div class="wine-club-faq__body">{{ block.settings.answer }}</div>
              {%- endif -%}
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Wine Club FAQ",
  "tag": "section",
  "class": "section-wine-club-faq",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    { "type": "text", "id": "eyebrow_text", "label": "Eyebrow", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Membership questions" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "xlarge", "label": "X-Large" }
      ],
      "default": "large"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Accordion width",
      "default": 760
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Can I skip or cancel a delivery?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Yes — you can pause, skip an upcoming shipment, or cancel your membership at any time from your account, with no lock-in contract.</p>"
        },
        {
          "type": "checkbox",
          "id": "default_open",
          "label": "Open by default",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Wine Club FAQ",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "Can I skip or cancel a delivery?",
            "answer": "<p>Yes — you can pause, skip an upcoming shipment, or cancel your membership at any time from your account, with no lock-in contract.</p>",
            "default_open": true
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "How is shipping handled?",
            "answer": "<p>All Wine Club deliveries within South Africa ship free, with tracked courier delivery and temperature-conscious packaging. International membership is available on request — contact us for details.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Can I change my case size or wines?",
            "answer": "<p>Yes — you can adjust your quantity ahead of each delivery, and swap out individual bottles for alternatives from the current selection before your case ships.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "What if a wine in my case is unavailable?",
            "answer": "<p>Our winemaking team selects a comparable substitute of equal or greater value from the current release, so your case is never short a bottle.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
