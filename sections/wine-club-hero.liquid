{%- comment -%}
  Wine Club hero — full-bleed image + overlay + editable text/CTAs
{%- endcomment -%}

{{ 'wine-club.css' | asset_url | stylesheet_tag }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

{%- liquid
  assign overlay = section.settings.overlay_opacity | default: 45 | divided_by: 100.0
  assign heading_size = section.settings.heading_size | default: 'large'
  assign h_align = section.settings.content_position | default: 'left'
  assign v_align = section.settings.content_alignment_vertical | default: 'bottom'
  assign min_h = section.settings.min_height | default: 340
  assign min_h_m = section.settings.mobile_min_height | default: 260
-%}

<section
  class="wine-club wine-club-hero"
  style="--wc-hero-min: {{ min_h }}px; --wc-hero-min-mobile: {{ min_h_m }}px; --wc-overlay: {{ overlay }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  {{ section.shopify_attributes }}
>
  {%- if section.settings.background_image != blank -%}
    <div class="wine-club-hero__media">
      {{
        section.settings.background_image
        | image_url: width: 2400
        | image_tag:
          widths: '800, 1200, 1600, 2000, 2400',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high',
          class: 'wine-club-hero__img',
          alt: section.settings.heading | default: page.title | escape
      }}
    </div>
  {%- else -%}
    <div class="wine-club-hero__empty">Add a background image in the theme editor</div>
  {%- endif -%}
  <div class="wine-club-hero__overlay" aria-hidden="true"></div>
  <div class="wine-club-hero__content wine-club-hero__content--h-{{ h_align }} wine-club-hero__content--v-{{ v_align }}">
    {%- if section.settings.eyebrow_text != blank -%}
      <div class="wine-club-hero__eyebrow">{{ section.settings.eyebrow_text }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="serif wine-club-hero__heading wine-club-hero__heading--{{ heading_size }}">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="wine-club__btn-row{% if h_align == 'center' %} wine-club__btn-row--center{% endif %}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'button' and block.settings.text != blank -%}
            <a
              href="{{ block.settings.link | default: '#' }}"
              class="wine-club__btn{% if block.settings.style == 'secondary' %} wine-club__btn--secondary{% endif %}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Wine Club hero",
  "tag": "section",
  "class": "section-wine-club-hero",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay darkness",
      "default": 45
    },
    { "type": "text", "id": "eyebrow_text", "label": "Eyebrow label", "default": "Membership" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Waterford Wine Club" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "xlarge", "label": "X-Large" }
      ],
      "default": "large"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "content_alignment_vertical",
      "label": "Vertical position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "bottom"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 240,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Hero height (desktop)",
      "default": 340
    },
    {
      "type": "range",
      "id": "mobile_min_height",
      "min": 160,
      "max": 400,
      "step": 20,
      "unit": "px",
      "label": "Hero height (mobile)",
      "default": 260
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "button",
      "name": "Button",
      "settings": [
        { "type": "text", "id": "text", "label": "Label", "default": "Join the Club" },
        { "type": "url", "id": "link", "label": "Link" },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "primary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Wine Club hero",
      "settings": {
        "eyebrow_text": "Membership",
        "heading": "The Waterford Wine Club"
      }
    }
  ]
}
{% endschema %}
