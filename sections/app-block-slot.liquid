{%- comment -%}
  Utility section: drop any app embed anywhere on a page.
{%- endcomment -%}

{{ 'wine-club.css' | asset_url | stylesheet_tag }}

<section
  class="wine-club wine-club-app-slot"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  {{ section.shopify_attributes }}
>
  <div class="wine-club__wrap">
    {%- for block in section.blocks -%}
      {%- if block.type == '@app' -%}
        <div {{ block.shopify_attributes }}>{% render block %}</div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "App block slot",
  "tag": "section",
  "class": "section-app-block-slot",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 24
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    { "name": "App block slot" }
  ]
}
{% endschema %}
