{%- comment -%}
  Build Your Case breadcrumb — Home › Wine Club › Build Your Case
{%- endcomment -%}

{{ 'build-your-case.css' | asset_url | stylesheet_tag }}

<section
  class="byc byc-breadcrumb"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  {{ section.shopify_attributes }}
>
  <div class="byc__wrap">
    <nav class="byc-breadcrumb__nav" aria-label="Breadcrumb">
      <a href="{{ section.settings.home_link | default: routes.root_url }}">
        {{ section.settings.home_label | default: 'Home' }}
      </a>
      &nbsp;&rsaquo;&nbsp;
      <a href="{{ section.settings.wine_club_link | default: '/pages/wine-club' }}">
        {{ section.settings.wine_club_label | default: 'Wine Club' }}
      </a>
      &nbsp;&rsaquo;&nbsp;
      <span>{{ section.settings.current_label | default: 'Build Your Case' }}</span>
    </nav>
  </div>
</section>

{% schema %}
{
  "name": "BYC breadcrumb",
  "tag": "section",
  "class": "section-build-your-case-breadcrumb",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "text", "id": "home_label", "label": "Home label", "default": "Home" },
    { "type": "url", "id": "home_link", "label": "Home link" },
    { "type": "text", "id": "wine_club_label", "label": "Wine Club label", "default": "Wine Club" },
    {
      "type": "url",
      "id": "wine_club_link",
      "label": "Wine Club link",
      "info": "Defaults to /pages/wine-club when blank"
    },
    {
      "type": "text",
      "id": "current_label",
      "label": "Current page label",
      "default": "Build Your Case"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    { "name": "BYC breadcrumb" }
  ]
}
{% endschema %}
