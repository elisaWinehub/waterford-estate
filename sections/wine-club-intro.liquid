{%- comment -%}
  Wine Club intro — centered page intro + CTA buttons
{%- endcomment -%}

{{ 'wine-club.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign align = section.settings.text_alignment | default: 'center'
  assign max_w = section.settings.max_width | default: 640
-%}

<section
  class="wine-club wine-club-intro color-{{ section.settings.color_scheme }}"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  {{ section.shopify_attributes }}
>
  <div class="wine-club__wrap">
    {%- if section.settings.show_breadcrumb -%}
      <div class="wine-club-intro__breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        &nbsp;&rsaquo;&nbsp;
        <span>{{ page.title | default: 'Wine Club' }}</span>
      </div>
    {%- endif -%}

    <div
      class="wine-club-intro__inner wine-club-intro__inner--{{ align }}"
      style="max-width: {{ max_w }}px;"
    >
      {%- if section.settings.heading != blank -%}
        <h2 class="serif wine-club__heading wine-club__heading--{{ section.settings.heading_size | default: 'medium' }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="wine-club-intro__text">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="wine-club__btn-row{% if align == 'center' %} wine-club__btn-row--center{% endif %}">
          {%- for block in section.blocks -%}
            {%- if block.type == 'button' and block.settings.text != blank -%}
              <a
                href="{{ block.settings.link | default: '#join' }}"
                class="wine-club__btn{% if block.settings.style == 'secondary' %} wine-club__btn--secondary{% endif %}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wine Club intro",
  "tag": "section",
  "class": "section-wine-club-intro",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    { "type": "text", "id": "heading", "label": "Optional supporting heading" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "xlarge", "label": "X-Large" }
      ],
      "default": "medium"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text",
      "default": "<p>A curated case of our finest releases, delivered to your door every quarter — with member pricing, priority allocation on limited releases, and complimentary tastings at the estate.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Reading width",
      "default": 640
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "button",
      "name": "Button",
      "settings": [
        { "type": "text", "id": "text", "label": "Label", "default": "Join the Club" },
        { "type": "url", "id": "link", "label": "Link" },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "primary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Wine Club intro",
      "blocks": [
        { "type": "button", "settings": { "text": "Join the Club", "link": "#join" } }
      ]
    }
  ]
}
{% endschema %}
