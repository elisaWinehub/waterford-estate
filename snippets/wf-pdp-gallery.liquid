{%- doc -%}
  PDP gallery — mockup classes (.gallery / .pdp-photo / .thumb-row / .thumb)
  Main image covers .pdp-photo; click opens zoom lightbox.
  @param {object} product
  @param {object} block
{%- enddoc -%}

{%- liquid
  assign featured = product.selected_or_first_available_variant.featured_media | default: product.featured_media
  if featured == blank and product.media.size > 0
    assign featured = product.media.first
  endif
-%}

<div class="gallery" {{ block.shopify_attributes }} data-wf-gallery>
  <div class="pdp-photo" data-wf-zoom-trigger role="button" tabindex="0" aria-label="Zoom image">
    {%- if featured != blank -%}
      {%- assign main_alt = featured.alt | default: product.title | escape -%}
      <img
        id="mainImg"
        src="{{ featured | image_url: width: 1200 }}"
        srcset="{{ featured | image_url: width: 400 }} 400w, {{ featured | image_url: width: 800 }} 800w, {{ featured | image_url: width: 1200 }} 1200w"
        sizes="(min-width: 901px) 40vw, 100vw"
        alt="{{ main_alt }}"
        loading="eager"
        fetchpriority="high"
        data-wf-main-img
        data-zoom-src="{{ featured | image_url: width: 2000 }}"
      >
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag }}
    {%- endif -%}
  </div>

  {%- if product.media.size > 1 -%}
    <div class="thumb-row">
      {%- for media in product.media -%}
        {%- if media.media_type == 'image' -%}
          {%- assign thumb_alt = media.alt | default: product.title | escape -%}
          <button
            type="button"
            class="thumb{% if media == featured %} active{% endif %}"
            data-wf-thumb
            data-alt="{{ thumb_alt }}"
            data-full-src="{{ media | image_url: width: 1200 }}"
            data-zoom-src="{{ media | image_url: width: 2000 }}"
            aria-label="{{ thumb_alt }}"
            aria-pressed="{% if media == featured %}true{% else %}false{% endif %}"
          >
            <img
              src="{{ media | image_url: width: 160 }}"
              alt="{{ thumb_alt }}"
              loading="lazy"
              width="64"
              height="78"
            >
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>
