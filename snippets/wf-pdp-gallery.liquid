{%- doc -%}
  Waterford PDP gallery: main image + thumbnail strip from product.media
  @param {object} product
  @param {object} block
{%- enddoc -%}

{%- liquid
  assign featured = product.selected_or_first_available_variant.featured_media | default: product.featured_media
  if featured == blank and product.media.size > 0
    assign featured = product.media.first
  endif
-%}

<div class="wf-gallery" {{ block.shopify_attributes }}>
  <div class="wf-pdp-photo">
    {%- if featured != blank -%}
      {%- assign main_alt = featured.alt | default: product.title | escape -%}
      {{
        featured
        | image_url: width: 1200
        | image_tag:
          widths: '400, 600, 800, 1000, 1200',
          sizes: '(min-width: 901px) 40vw, 100vw',
          loading: 'eager',
          fetchpriority: 'high',
          alt: main_alt,
          data-wf-main-img: '1',
          id: 'wf-main-img'
      }}
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag }}
    {%- endif -%}
  </div>

  {%- if product.media.size > 1 -%}
    <div class="wf-thumb-row" role="list">
      {%- for media in product.media -%}
        {%- if media.media_type == 'image' -%}
          {%- assign thumb_alt = media.alt | default: product.title | escape -%}
          <button
            type="button"
            class="wf-thumb{% if media == featured %} active{% endif %}"
            data-wf-thumb
            data-alt="{{ thumb_alt }}"
            aria-label="{{ thumb_alt }}"
            aria-pressed="{% if media == featured %}true{% else %}false{% endif %}"
            role="listitem"
          >
            {{
              media
              | image_url: width: 160
              | image_tag:
                widths: '80, 120, 160',
                sizes: '64px',
                loading: 'lazy',
                alt: thumb_alt
            }}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>
