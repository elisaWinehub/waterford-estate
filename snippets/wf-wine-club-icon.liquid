{%- doc -%}
  Wine Club preset icons (membership / shipping / wine).
  @param {string} icon - case | tag | star | truck | wine_glass | calendar | pause
{%- enddoc -%}

{%- case icon -%}
  {%- when 'case' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="8" width="18" height="12" rx="1"></rect>
      <path d="M3 12h18"></path>
      <path d="M8 8V6a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
    </svg>
  {%- when 'tag' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M20.6 12.6 12.6 20.6a2 2 0 0 1-2.8 0l-7.4-7.4V5a2 2 0 0 1 2-2h8.2z"></path>
      <circle cx="7.5" cy="7.5" r="1.2"></circle>
    </svg>
  {%- when 'star' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 17.3 6.2 20.5l1.1-6.5L2.6 9.3l6.5-1L12 2.3l2.9 6 6.5 1-4.7 4.7 1.1 6.5z"></path>
    </svg>
  {%- when 'truck' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="1" y="6" width="14" height="11" rx="1"></rect>
      <path d="M15 9h3.5L21 12v5h-6z"></path>
      <circle cx="6" cy="19" r="1.6"></circle>
      <circle cx="17.5" cy="19" r="1.6"></circle>
    </svg>
  {%- when 'wine_glass' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M8 3h8l-1 9a4 4 0 0 1-6 0L8 3z"></path>
      <path d="M12 12v7"></path>
      <path d="M8 21h8"></path>
    </svg>
  {%- when 'calendar' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M8 3v3M16 3v3M4 10h16"></path>
      <rect x="4" y="6" width="16" height="15" rx="2"></rect>
      <path d="M9 14h6"></path>
    </svg>
  {%- when 'pause' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 12a8 8 0 1 1 3 6.3"></path>
      <path d="M4 17v-5h5"></path>
    </svg>
  {%- else -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="5" width="18" height="16" rx="2"></rect>
      <path d="M8 3v4M16 3v4M3 10h18"></path>
    </svg>
{%- endcase -%}
